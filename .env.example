# Telegram API credentials (https://my.telegram.org)
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here
TG_SESSION_NAME=userbot

# Phone number for login (international format)
TG_PHONE=+8613800138000

# Bot admin user IDs (comma-separated Telegram user IDs)
ADMIN_USER_IDS=123456789

# FastAPI management API
API_HOST=0.0.0.0
API_PORT=8080
API_SECRET_KEY=change-this-to-a-random-secret-key

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/userbot.db

# Command reply auto-delete (seconds, 0 = keep forever)
CMD_DELETE_AFTER=0

# Media download directory
DOWNLOAD_DIR=downloads
DOWNLOAD_THREADS=4
DOWNLOAD_PART_SIZE_KB=512

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/userbot.log

# Proxy (optional)
# Supported schemes: socks5, socks4, http
# Format: scheme://[user:pass@]host:port
# Examples:
#   TG_PROXY_TYPE=socks5
#   TG_PROXY_HOST=127.0.0.1
#   TG_PROXY_PORT=7890
#   TG_PROXY_USER=
#   TG_PROXY_PASS=
TG_PROXY_TYPE=
TG_PROXY_HOST=
TG_PROXY_PORT=
TG_PROXY_USER=
TG_PROXY_PASS=
